# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
SERVER_PORT=8080

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=skeleton_db
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# ── Logger ─────────────────────────────────────────────────────────────────────
# Accepted values: debug | info | warn | error
LOG_LEVEL=debug

# ── External API ───────────────────────────────────────────────────────────────
EXTERNAL_API_BASE_URL=https://jsonplaceholder.typicode.com
EXTERNAL_API_TIMEOUT_SEC=10
